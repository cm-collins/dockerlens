# ─── Rust ────────────────────────────────────────────────────────────────────

# Generated by Cargo — compiled files and executables
debug/
target/

# Rust backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows debugging info
*.pdb

# cargo-mutants mutation testing output
**/mutants.out*/

# ─── Tauri ───────────────────────────────────────────────────────────────────

# Tauri build output (separate from workspace target)
src-tauri/target/
src-tauri/WixTools/

# Tauri bundled artifacts — never commit these
*.AppImage
*.deb
*.rpm
*.dmg
*.msi
*.exe

# ─── Node / Frontend ─────────────────────────────────────────────────────────

node_modules/
dist/
dist-ssr/
.pnpm-store/
.pnpm-debug.log*

# ─── Environment ─────────────────────────────────────────────────────────────

# Never commit secrets — use .env.local.example as the committed template
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ─── IDEs & Editors ──────────────────────────────────────────────────────────

# VS Code — keep shared team config, ignore personal/machine-specific files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/mcp.json

# JetBrains / RustRover
.idea/
*.iml

# Vim / Neovim
*.swp
*.swo
*~

# Cursor AI
.cursor/*
!.cursor/README.md
!.cursor/commands/
!.cursor/prompts/
!.cursor/skills/

# ─── OS ──────────────────────────────────────────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
.fuse_hidden*
.Trash-*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Logs ────────────────────────────────────────────────────────────────────

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Lock files — keep these committed ───────────────────────────────────────

# Cargo.lock SHOULD be committed for application binaries (not libraries)
# pnpm-lock.yaml SHOULD be committed
# Do NOT add them here