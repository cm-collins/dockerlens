# =============================================================================
# DockerLens — .env.local.example
# Copy this file to .env.local and fill in your values.
#
# ⚠️  NEVER commit .env.local to git — it contains secrets
# ⚠️  NEVER use production values here — use a dev Supabase project
#
# How to use:
#   cp .env.local.example .env.local
#
# How to get Supabase values:
#   Supabase Dashboard → Project → Settings → API
# =============================================================================


# =============================================================================
# Supabase — auth, settings sync + database migrations
# Supabase Dashboard → Project → Settings → API
# =============================================================================

# Project URL
# Format: https://<project-ref>.supabase.co
DOCKERLENS_SUPABASE_URL=

# Anon/public key — safe for frontend use
# Starts with: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# NEVER use the service_role key here — it bypasses all RLS
DOCKERLENS_SUPABASE_ANON_KEY=

# Dev database connection URI — used by db/validate-migrations.sh and db/apply-migrations.sh
# Supabase Dashboard → Project → Settings → Database → Connection string (URI mode)
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DOCKERLENS_SUPABASE_DB_URL=


# =============================================================================
# App metadata — safe to commit in .env, kept here for dev convenience
# =============================================================================

DOCKERLENS_APP_NAME=DockerLens
DOCKERLENS_APP_VERSION=0.1.0-alpha
DOCKERLENS_APP_ENV=development


# =============================================================================
# Docker — optional overrides for development
# =============================================================================

# Override the Docker socket path during development
# Leave empty to use auto-detection (recommended)
# Standard Docker:  /var/run/docker.sock
# Rootless Docker:  /run/user/<uid>/docker.sock
DOCKERLENS_DOCKER_SOCKET_PATH=


# =============================================================================
# DO NOT ADD BELOW THIS LINE
# These belong in GitHub Secrets only — never in any .env file:
#   TAURI_SIGNING_PRIVATE_KEY
#   TAURI_SIGNING_PRIVATE_KEY_PASSWORD
#   GPG_SIGNING_KEY
#   SUPABASE_SERVICE_ROLE_KEY
#   DOCKERLENS_SUPABASE_DB_URL_PROD
# =============================================================================
